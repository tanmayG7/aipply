rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // CV Orders Collection
    match /cv_orders/{orderId} {
      // Allow authenticated users to create their own orders
      allow create: if request.auth != null &&
                       request.resource.data.userId == request.auth.uid;

      // Allow users to read their own orders
      allow read: if request.auth != null &&
                     resource.data.userId == request.auth.uid;

      // Allow updates to order status (for payment verification)
      allow update: if request.auth != null &&
                       resource.data.userId == request.auth.uid;
    }

    // Users Collection
    match /users/{userId} {
      // Users can read and write their own profile
      allow read, write: if request.auth != null &&
                            request.auth.uid == userId;
    }

    // Subscriptions Collection
    match /subscriptions/{subscriptionId} {
      // Users can read and write their own subscriptions
      allow read, write: if request.auth != null &&
                            resource.data.userId == request.auth.uid;

      // Allow creation of subscriptions
      allow create: if request.auth != null &&
                       request.resource.data.userId == request.auth.uid;
    }

    // Job Applications Collection (if exists)
    match /applications/{applicationId} {
      // Users can read and write their own applications
      allow read, write: if request.auth != null &&
                            resource.data.userId == request.auth.uid;

      // Allow creation
      allow create: if request.auth != null;
    }

    // Dashboard Data Collection
    match /dashboardData/{userId} {
      // Users can read and write their own dashboard data
      allow read, write: if request.auth != null &&
                            request.auth.uid == userId;
    }

    // Applied Jobs Collection
    match /appliedJobs/{userId} {
      // Users can read and write their own applied jobs
      allow read, write: if request.auth != null &&
                            request.auth.uid == userId;
    }

    // Current Jobs Collection
    match /currentJobs/{userId} {
      // Users can read and write their own current jobs
      allow read, write: if request.auth != null &&
                            request.auth.uid == userId;
    }

    // Archived Jobs Collection
    match /archiveJobs/{userId} {
      // Users can read and write their own archived jobs
      allow read, write: if request.auth != null &&
                            request.auth.uid == userId;
    }

    // Hidden Jobs Collection
    match /hiddenJobs/{userId} {
      // Users can read and write their own hidden jobs
      allow read, write: if request.auth != null &&
                            request.auth.uid == userId;
    }

    // Contact Submissions Collection
    match /contactSubmissions/{submissionId} {
      // Allow authenticated users to create contact submissions
      allow create: if request.auth != null;
      // Admin-only read access (deny for regular users)
      allow read: if false;
    }

    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
