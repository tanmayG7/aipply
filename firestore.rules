rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========== HELPER FUNCTIONS ==========

    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if user has admin claim (for Admin panel)
    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    // Allow server-side operations (for cron jobs and API routes)
    // These operations come from Next.js API routes using Admin SDK
    // They don't have user auth context but need to query collections
    function isServerOperation() {
      // Allow unauthenticated requests (Admin SDK from server context)
      // This is safe because:
      // 1. Only server-side code can make these requests
      // 2. Client apps MUST authenticate (enforced by client SDK)
      // 3. We limit this to read operations only on specific collections
      return request.auth == null;
    }

    // ========== CV ORDERS COLLECTION ==========
    match /cv_orders/{orderId} {
      allow create: if isAuthenticated() &&
                       request.resource.data.userId == request.auth.uid;
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow update: if isOwner(resource.data.userId) || isAdmin();
    }

    // ========== USERS COLLECTION ==========
    match /users/{userId} {
      // Users can access their own data, admins can access all
      // Server operations can read for automation (e.g., auto-apply needs user profiles)
      allow read: if isOwner(userId) || isAdmin() || isServerOperation();
      allow write: if isOwner(userId) || isAdmin();
    }

    // ========== SUBSCRIPTIONS COLLECTION ==========
    match /subscriptions/{subscriptionId} {
      // Critical: Allow server operations to query subscriptions for auto-apply cron
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid ||
                     isAdmin() ||
                     isServerOperation();
      allow write: if isAuthenticated() && resource.data.userId == request.auth.uid ||
                      isAdmin() ||
                      isServerOperation();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // ========== JOB APPLICATIONS COLLECTION ==========
    match /applications/{applicationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid || isAdmin();
      allow write: if isAuthenticated() && resource.data.userId == request.auth.uid || isAdmin();
      allow create: if isAuthenticated();
    }

    // ========== DASHBOARD DATA COLLECTION ==========
    match /dashboardData/{userId} {
      allow read: if isOwner(userId) || isAdmin() || isServerOperation();
      allow write: if isOwner(userId) || isAdmin() || isServerOperation();
    }

    // ========== APPLIED JOBS COLLECTION ==========
    match /appliedJobs/{userId} {
      // Server operations can write (auto-apply script writes application records)
      allow read: if isOwner(userId) || isAdmin() || isServerOperation();
      allow write: if isOwner(userId) || isAdmin() || isServerOperation();
    }

    // ========== CURRENT JOBS COLLECTION ==========
    match /currentJobs/{userId} {
      allow read: if isOwner(userId) || isAdmin() || isServerOperation();
      allow write: if isOwner(userId) || isAdmin() || isServerOperation();
    }

    // ========== ARCHIVED JOBS COLLECTION ==========
    match /archiveJobs/{userId} {
      allow read: if isOwner(userId) || isAdmin() || isServerOperation();
      allow write: if isOwner(userId) || isAdmin() || isServerOperation();
    }

    // ========== HIDDEN JOBS COLLECTION ==========
    match /hiddenJobs/{userId} {
      allow read: if isOwner(userId) || isAdmin() || isServerOperation();
      allow write: if isOwner(userId) || isAdmin() || isServerOperation();
    }

    // ========== USER DETAILS COLLECTION ==========
    match /userDetails/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    // ========== CONTACT SUBMISSIONS COLLECTION ==========
    match /contactSubmissions/{submissionId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
    }

    // ========== DEFAULT DENY ==========
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
