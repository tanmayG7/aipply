{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "source": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "frameworksBackend": {
      "region": "us-central1",
      "minInstances": 0,
      "maxInstances": 10,
      "concurrency": 80,
      "cpu": 1,
      "memory": "512MiB",
      "timeoutSeconds": 60
    }
  }
}
